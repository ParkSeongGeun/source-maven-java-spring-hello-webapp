pipeline {

        agent none

        stages {
                stage('Checkout') {
			agent {
				docker { image 'maven:3-openjdk-17' }
			}

                        steps {
                                git branch: 'main',
                                url: 'https://github.com/ParkSeongGeun/source-maven-java-spring-hello-webapp.git'
                        }
                }

                stage('Build') {
			agent {
                                docker { image 'maven:3-openjdk-17' }
                        }

                        steps {
                                sh 'mvn clean package -DskipTests=true'
                        }
                }

                stage('Test') {
                        agent {
                                docker { image 'maven:3-openjdk-17' }
                        }

                        steps {
                 		sh 'mvn test'
                        }
                }
		
		stage('Build Docker Image') {
			agent { label 'controller' }
			
			steps {
				sh 'docker image build -t phd0801/tomcat:v$BUILD_NUMBER .'
			}	
		}

		stage('Tag Docker Image') {
			agent { label 'controller' }
			steps {
				sh 'docker image tag phd0801/tomcat:v$BUILD_NUMBER phd0801/tomcat:latest'
			}
		}

		stage('Publish Docker Image') {
			agent { label 'controller' }
			steps {
				withDockerRegistry(credentialsId: 'docker-registry-credential', url: 'https://index.docker.io/v1/') {
				sh 'docker image push phd0801/tomcat:v$BUILD_NUMBER'
				sh 'docker image push phd0801/tomcat:latest'
				}
			}
		}

		stage('Run Docker Container') {
			agent { label 'controller' }
			steps {
				sh 'docker container run --detach --name webserver -p 80:8080 phd0801/tomcat:latest'
			}
		}
        }
}

